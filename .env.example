# Banco de Dados
DATABASE_URL=sqlite:///instance/database.db

# Segurança Base
SECRET_KEY=troque-esta-chave-em-producao
FLASK_ENV=development
FLASK_DEBUG=true

# Bootstrap administrativo
ADMIN_EMAIL=admin@email.com
ADMIN_NAME=Administrador
ADMIN_DEFAULT_PASSWORD=senha@123
ADMIN_FORCE_PASSWORD_CHANGE=true

# LDAP / AD
LDAP_SERVER_URI=
LDAP_USE_SSL=true
LDAP_CONNECT_TIMEOUT=10

# -----------------------------------------------------------------------------
# Google Calendar (Serviço Social — app/services/calendar_service.py)
# -----------------------------------------------------------------------------
# ID do calendário onde os eventos são criados (ex.: xxxx@group.calendar.google.com).
# O calendário deve estar compartilhado com o e-mail da conta de serviço (client_email do JSON).
GOOGLE_CALENDAR_ID=c_4632f62fda3efe957dfb7e6e052ce9eb2c9b2b9dd36f2faaf173eb86865c848d@group.calendar.google.com

# Caminho absoluto para o JSON da conta de serviço (fora do repositório).
# Exemplo Windows: C:/inetpub/secrets/pautaon-google-calendar.json
# Exemplo Linux:   /etc/pautaon/secrets/pautaon-google-calendar.json
GOOGLE_SERVICE_ACCOUNT_FILE=C:\Users\FMtic\Documents\Nextcloud\MeusDados\FMtic\SysAdmin\Chave$\Google\pautaon-google-calendar.json

# Opcional: impersonação (domain-wide delegation no Google Workspace).
# Só preencha se a TI configurar delegação para esta service account.
# Exemplo: coordenacao@escola.edu.br
GOOGLE_CALENDAR_DELEGATED_USER=

# Escopo OAuth fixo no código (config.py) — não há variável de ambiente:
#   https://www.googleapis.com/auth/calendar

# -----------------------------------------------------------------------------
# Google Chat — Notificador de pauta (scripts/notificador.py)
# -----------------------------------------------------------------------------
# JSON da conta de serviço com permissão para Chat API.
# Se vazio, o notificador usa GOOGLE_SERVICE_ACCOUNT_FILE (mesmo arquivo do Calendar),
# desde que a conta no Google Cloud tenha escopos de Chat habilitados.
GOOGLE_CHAT_SERVICE_ACCOUNT_FILE=C:\Users\FMtic\Documents\Nextcloud\MeusDados\FMtic\SysAdmin\Chave$\Google\pautaon-google-chat.json

# Escopos separados por vírgula (padrão usado pelo script).
GOOGLE_CHAT_SCOPES=https://www.googleapis.com/auth/chat.messages.create,https://www.googleapis.com/auth/chat.spaces

# Dias após a data da aula para enviar lembrete (padrão 7).
NOTIFICADOR_DIAS_ATRASO=7

# true = apenas loga o que seria enviado, sem chamar a API do Chat.
NOTIFICADOR_DRY_RUN=true

# DEBUG, INFO, WARNING ou ERROR
NOTIFICADOR_LOG_LEVEL=INFO
